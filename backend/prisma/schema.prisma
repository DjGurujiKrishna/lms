// LMS MVP — PostgreSQL (Supabase). Tenant isolation via instituteId on core rows.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


// Roles are stored on User.role
enum Role {
  SUPER_ADMIN
  ADMIN
  INSTITUTION_ADMIN
  TEACHER
  STUDENT
}

model Institute {
  id        String @id @default(uuid())
  name      String
  subdomain String @unique

  users   User[]
  courses Course[]
}

model User {
  id          String @id @default(uuid())
  name        String
  email       String @unique
  password    String // bcrypt hash
  role        Role
  instituteId String

  institute   Institute    @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]
  results     Result[]

  @@index([instituteId])
}

model Course {
  id          String @id @default(uuid())
  name        String
  instituteId String

  institute   Institute    @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  subjects    Subject[]
  enrollments Enrollment[]
  exams       Exam[]

  @@index([instituteId])
}

model Subject {
  id       String @id @default(uuid())
  name     String
  courseId String

  course   Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  contents Content[]

  @@index([courseId])
}

model Content {
  id        String @id @default(uuid())
  title     String
  type      String
  fileUrl   String
  subjectId String

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([subjectId])
}

model Enrollment {
  id        String @id @default(uuid())
  studentId String
  courseId  String

  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([studentId])
}

model Exam {
  id       String @id @default(uuid())
  title    String
  courseId String
  duration Int

  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions Question[]
  results   Result[]

  @@index([courseId])
}

model Question {
  id       String @id @default(uuid())
  examId   String
  question String
  options  Json
  answer   String

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
}

model Result {
  id        String @id @default(uuid())
  studentId String
  examId    String
  score     Int

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exam    Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([studentId, examId])
  @@index([examId])
}
