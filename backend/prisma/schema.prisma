// LMS MVP — PostgreSQL (Supabase). Tenant isolation via instituteId on core rows.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


// Roles are stored on User.role
enum Role {
  SUPER_ADMIN
  ADMIN
  INSTITUTION_ADMIN
  TEACHER
  STUDENT
}

model Institute {
  id        String @id @default(uuid())
  name      String
  subdomain String @unique

  users   User[]
  courses Course[]
  contentViews ContentView[]
}

model User {
  id          String @id @default(uuid())
  name        String
  email       String @unique
  mobile      String?
  password    String // bcrypt hash
  role        Role
  instituteId String
  createdAt   DateTime @default(now())

  institute   Institute    @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]
  results     Result[]
  teacherSubjects TeacherSubject[]
  contentViews ContentView[]
  assignmentSubmissions AssignmentSubmission[]

  @@index([instituteId])
}

model Course {
  id          String @id @default(uuid())
  name        String
  instituteId String

  institute   Institute    @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  subjects    Subject[]
  enrollments Enrollment[]
  exams       Exam[]

  @@index([instituteId])
}

model Subject {
  id       String @id @default(uuid())
  name     String
  courseId String

  course   Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  contents Content[]
  categories ContentCategory[]
  teacherSubjects TeacherSubject[]
  enrollments Enrollment[]
  assignments Assignment[]

  @@index([courseId])
}

model ContentCategory {
  id          String @id @default(uuid())
  name        String
  description String?
  subjectId   String

  subject  Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  contents Content[]

  @@index([subjectId])
}

model Content {
  id          String  @id @default(uuid())
  title       String
  description String?
  type        String
  fileUrl     String
  subjectId   String
  categoryId  String?

  subject  Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  category ContentCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  views    ContentView[]

  @@index([subjectId])
  @@index([categoryId])
}

model ContentView {
  id          String @id @default(uuid())
  instituteId String
  studentId   String
  contentId   String
  createdAt   DateTime @default(now())

  student   User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  content   Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)
  institute Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)

  @@index([instituteId, createdAt])
  @@index([studentId, createdAt])
  @@index([contentId, createdAt])
}

model Enrollment {
  id        String @id @default(uuid())
  studentId String
  courseId  String
  subjectId String?
  createdAt DateTime @default(now())

  student User   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  subject Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@unique([studentId, courseId])
  @@index([studentId])
}

/** Teacher → Subject assignments (used to infer courses). */
model TeacherSubject {
  id        String @id @default(uuid())
  teacherId String
  subjectId String

  teacher User    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId])
  @@index([teacherId])
}

model Exam {
  id       String @id @default(uuid())
  title    String
  courseId String
  duration Int

  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions Question[]
  results   Result[]

  @@index([courseId])
}

model Question {
  id       String @id @default(uuid())
  examId   String
  question String
  options  Json
  answer   String

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@index([examId])
}

model Result {
  id        String @id @default(uuid())
  studentId String
  examId    String
  score     Int
  createdAt DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exam    Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([studentId, examId])
  @@index([examId])
  @@index([studentId])
}

model Assignment {
  id          String    @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime?
  isPublished Boolean   @default(true)
  subjectId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  subject     Subject              @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  questions   AssignmentQuestion[]
  submissions AssignmentSubmission[]

  @@index([subjectId])
}

model AssignmentQuestion {
  id           String  @id @default(uuid())
  assignmentId String
  text         String
  imageUrl     String?
  pdfUrl       String?

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
}

model AssignmentSubmission {
  id           String   @id @default(uuid())
  assignmentId String
  studentId    String
  fileUrl      String    // PDF or Image uploaded by student
  submittedAt  DateTime @default(now())

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
}
